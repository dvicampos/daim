<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Formulario Bootstrap - Paso 1</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .card {
            border-radius: 12px;
            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.1);
            margin-top: 50px;
        }
        .step-indicator {
            font-size: 1.1rem;
            font-weight: bold;
        }
        .progress {
            height: 8px;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card p-4">
                
                <!-- Indicador de paso -->
                <div class="text-center mb-3">
                    <span class="step-indicator">Paso 1 de 2: Información de la Empresa</span>
                    <div class="progress mt-2">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: 50%;" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>

                <h3 class="text-center mb-3">Crear Grupo</h3>
                
                <form action="/create-group" method="POST" id="grupoForm">
                    
                    <!-- Nombre de Empresa (fila completa) -->
                    <div class="mb-3">
                        <label class="form-label">Nombre de mi empresa:</label>
                        <input type="text" class="form-control" name="nombre_empresa" id="nombre_empresa" required>
                    </div>

                    <!-- Rubro y Ubicación (2 columnas) -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Rubro:</label>
                            <input type="text" class="form-control" name="rubro">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ubicación:</label>
                            <input type="text" class="form-control" name="ubicacion">
                        </div>
                    </div>

                    <!-- Horario y Teléfono (2 columnas) -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Horario:</label>
                            <input type="text" class="form-control" name="horario">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Teléfono:</label>
                            <input type="text" class="form-control" name="telefono">
                        </div>
                    </div>

                    <!-- Email (fila completa) -->
                    <div class="mb-3">
                        <label class="form-label">Email:</label>
                        <input type="email" class="form-control" name="email">
                    </div>

                    <!-- Redes Sociales (2 columnas) -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Facebook:</label>
                            <input type="text" class="form-control" name="facebook">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">TikTok:</label>
                            <input type="text" class="form-control" name="tiktok">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Descripción:</label>
                        <textarea class="form-control" name="descripcion" rows="3"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Siguiente paso</button>
                    <p class="mt-3">¿Ya tienes una cuenta? <a href="/login">Inicia sesion</a></p>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById("grupoForm").addEventListener("submit", function(event) {
        const nombreEmpresa = document.getElementById("nombre_empresa").value;
        localStorage.setItem("nombre_empresa", nombreEmpresa);
    });
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
