<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Alquiladora DAIM</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.1.0/dist/css/adminlte.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/font-awesome/css/font-awesome.min.css">
    <link rel="stylesheet" href="https://code.jquery.com/jquery-3.5.1.slim.min.js">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
	<link rel="shortcut icon" href="/img/logo_daim.png" type="image/x-icon">
</head>
<body class="hold-transition sidebar-mini layout-fixed">
    <div class="wrapper">
        <!-- Navbar -->
        <nav class="main-header navbar navbar-expand navbar-white navbar-light">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fa fa-bars"></i></a>
                </li>
            </ul>
            <div class="float-right d-sm-inline">
                <b>Hora:</b> <span id="version-hora"></span>
            </div>
        </nav>

        <!-- Sidebar -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <a href="/" class="brand-link">
                <img style="width: 10%;" src="/img/logo_daim.png" alt="Logo de la Empresa">
                <span class="brand-text font-weight-light">
                    <%= grupo %>
                </span>
            </a>            
            <div class="sidebar">
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu">
                        <li class="nav-item">
                            <a href="/clientes" class="nav-link">
                                <i class="nav-icon fa fa-user"></i>
                                <p>Clientes</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/encargados" class="nav-link">
                                <i class="nav-icon fa fa-users-gear"></i>
                                <p>Administradores</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/casos" class="nav-link">
                                <i class="nav-icon fa fa-table"></i>
                                <p>Rentas</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/categorias" class="nav-link">
                                <i class="nav-icon fa fa-tag"></i>
                                <p>Categorías</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/notas" class="nav-link">
                                <i class="nav-icon fa-solid fa-note-sticky"></i>
                                <p>Notas</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/recordatorios" class="nav-link">
                                <i class="nav-icon fa-solid fa-business-time"></i>
                                <p>Recordatorios</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/edit-group" class="nav-link">
                                <i class="nav-icon fa fa-building"></i>
                                <p>Editar Grupo</p>
                            </a>
                        </li>                        
                        <li class="nav-item">
                            <a href="/logout" class="nav-link">
                                <i class=" text-danger fa fa-sign-out"></i>
                                <p class="text-danger">Cerrar Sesión</p>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </aside>

        <!-- Content Wrapper -->
        <div class="content-wrapper">
            <section class="content">
                <div class="container-fluid">
                    <%- body %>
                </div>
            </section>
        </div>

        <!-- Footer -->
        <footer class="main-footer">
            <strong>&copy; 2025 Sistema DAIM.</strong> Impulsado por <a target="_blank" href="https://davanitechnology.com/">Davani Technology</a>.
        </footer>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.1.0/dist/js/adminlte.min.js"></script>
    <script>
        function actualizarHora() {
            const ahora = new Date();
            const horaFormateada = ahora.toLocaleTimeString(); // Formato HH:MM:SS
            document.getElementById("version-hora").innerText = horaFormateada;
        }

        actualizarHora(); // Llamar una vez al cargar la página
        setInterval(actualizarHora, 1000);
    </script>
</body>
</html>
