<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= grupo.nombre_empresa %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f4f4f9;
            margin: 0;
            padding: 0;
        }
        header {
            text-align: center;
            padding: 30px 20px;
            background-color: #031930;
            color: white;
        }
        header h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }
        header img {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 5px solid white;
            margin-top: 10px;
        }
        section {
            padding: 20px;
            text-align: center;
        }
        .empresa-info {
            margin-top: 20px;
            font-size: 1.1rem;
            line-height: 1.8;
            color: #555;
        }
        .empresa-info p {
            margin: 10px 0;
        }
        .social-links {
            margin-top: 40px;
            display: flex;
            justify-content: center;
            gap: 20px;
        }
        .social-links a {
            display: inline-block;
            padding: 10px 20px;
            font-size: 20px;
            text-decoration: none;
            color: white;
            border-radius: 5px;
        }
        .btn-facebook {
            background-color: #3b5998;
        }
        .btn-tiktok {
            background-color: #ff0050;
        }
        .btn-facebook:hover, .btn-tiktok:hover {
            opacity: 0.9;
        }
        footer {
            background-color: #333;
            color: white;
            text-align: center;
            padding: 15px 10px;
            margin-top: 30px;
            font-size: 0.9rem;
        }
        .whatsapp-btn {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background-color: #25D366;
            color: white;
            padding: 15px 20px;
            border-radius: 50%;
            box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.2);
            text-decoration: none;
            font-size: 24px;
        }
        .whatsapp-btn:hover {
            background-color: #1ebe5b;
        }
        .whatsapp-btn i {
            margin-right: 5px;
        }
    </style>
</head>
<body>

<header>
    <h1><%= grupo.nombre_empresa %></h1>
    <% if (grupo.foto_perfil) { %>
        <img src="/<%= grupo.foto_perfil %>" alt="Logo de <%= grupo.nombre_empresa %>">
    <% } %>
    <p><strong>Servicios:</strong> <%= grupo.rubro %></p>
</header>

<section>
    <h2>Sobre nosotros</h2>
    <div class="empresa-info">
        <p><strong>Descripción:</strong> <%= grupo.descripcion %></p>
        <p><strong>Ubicación:</strong> <%= grupo.ubicacion %></p>
        <p><strong>Horario:</strong> <%= grupo.horario %></p>
        <p><strong>Teléfono:</strong> <%= grupo.telefono %></p>
        <p><strong>Email:</strong> <%= grupo.email %></p>
    </div>
</section>

<section>
    <h2>Conéctate con nosotros</h2>
    <div class="social-links">
        <% if (grupo.facebook) { %>
            <a href="<%= grupo.facebook %>" target="_blank" class="btn-facebook">
                <i class="bi bi-facebook"></i> Facebook
            </a>
        <% } %>
        <% if (grupo.tiktok) { %>
            <a href="<%= grupo.tiktok %>" target="_blank" class="btn-tiktok">
                <i class="bi bi-tiktok"></i> TikTok
            </a>
        <% } %>
    </div>
</section>

<footer>
    <p>© <%= new Date().getFullYear() %> <%= grupo.nombre_empresa %>. Todos los derechos reservados.</p>
    <p><strong>Términos y Condiciones:</strong> <%= grupo.terminos %></p>
</footer>

<% if (grupo.telefono) { %>
    <a href="https://wa.me/<%= grupo.telefono.replace(/[^0-9]/g, '') %>" target="_blank" class="whatsapp-btn">
        <i class="bi bi-whatsapp"></i>
    </a>
<% } %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.min.js"></script>
</body>
</html>
